# Copy this file to .env and fill in the values. NEVER commit .env.
# These are every key/setting Phase A ("Proof of Loop") needs.

# --- Intelligence (T1, T3): Anthropic API / Claude ---
# Requires a non-zero account balance (free-trial credits are fine).
# Get one at https://console.anthropic.com/ -> API keys.
ANTHROPIC_API_KEY=

# --- Voice (T1, T4): ElevenLabs TTS ---
# Optional now — only needed if you set TTS_PROVIDER=elevenlabs (flagship voice).
# Free tier covers only ~2 segments/month. https://elevenlabs.io/ -> API key.
ELEVENLABS_API_KEY=

# Which TTS implementation the tts.py seam selects:
#   kokoro      DEFAULT — self-hosted open-weight neural voice; free, unlimited,
#               offline after the one-time model download (no key). See README
#               "Kokoro (local TTS)" for the install steps.
#   elevenlabs  flagship cloud voice (needs ELEVENLABS_API_KEY + credits; the
#               free tier runs dry fast). Reserved for later premium use.
#   say         macOS built-in `say` — offline fallback if Kokoro won't install.
#   orpheus     future self-hosted option, not built yet.
# Override per-run, e.g.:  TTS_PROVIDER=elevenlabs make play
TTS_PROVIDER=kokoro

# D9.0 — station-wide default emotion when a turn/segment sets none. One of:
# warm | wry | somber | bright | urgent (the vocabulary in src/providers/tts.py),
# or empty for the engine default. Audible ONLY on TTS_PROVIDER=elevenlabs —
# Kokoro/say have no emotion knob (the C6 launch-voice decision gates this).
TTS_EMOTION_DEFAULT=

# D9.1 — the pronunciation lexicon (invented names spoken right). The file is
# the human-edited source of truth — fix a mispronunciation by editing it, no
# code change or restart needed. TTS_LEXICON_ENABLED=false switches it off.
TTS_LEXICON_ENABLED=true
# TTS_LEXICON_PATH  — the lexicon file. Default config/pronunciation.yaml.
# TTS_LEXICON_PATH=config/pronunciation.yaml

# D9.2 — the voice registry (logical voice -> vendor preset, per engine). The
# file is the human-edited source of truth: adding a DJ = a card in the bible +
# one entry there (+ `make seed-canon`) — no code change. REQUIRED at render.
# TTS_VOICES_PATH  — the registry file. Default config/voices.yaml.
# TTS_VOICES_PATH=config/voices.yaml

# D9.3 — guest / non-host voices (a figure soundbite or a one-off invited
# guest in a talk segment; sparse texture). CONVO_GUEST_CHANCE is the share of
# talk slots that carry one (0..1); CONVO_GUEST_ENABLED=false = host-only.
CONVO_GUEST_ENABLED=true
# CONVO_GUEST_CHANCE=0.2

# D9.4 — DJ memory: hosts recall recent past stories from the log as lived
# history (persona-weighted, past-tense framed, checked by the continuity
# editor). Bounded by a look-back window + a per-host cap.
CONVO_MEMORY_ENABLED=true
# CONVO_MEMORY_PER_HOST=3
# CONVO_MEMORY_WINDOW_DAYS=60

# --- Playout (T5): local Icecast ---
# Password Liquidsoap uses to push the stream into Icecast. Local-only, so any
# value works; this default is fine if you don't change it on both sides.
ICECAST_SOURCE_PASSWORD=hackme

# --- Foundation (B0.5): config + logging -------------------------------------
# EVERY field in src/config.py can be overridden by an env var of the same name
# (case-insensitive), so you rarely need to set these — the defaults are sane.
# The most useful knobs:
#
# Logging: level (debug|info|warning|error) and format. LOG_JSON=false gives
# human-pretty console output for local dev; true (default) is JSON for 24/7.
# LOG_LEVEL=info
# LOG_JSON=true
#
# Bounded retry on external (Claude/TTS) calls.
# RETRY_ATTEMPTS=3
# RETRY_BACKOFF_SEC=2.0
#
# World-state database (B1). Local PostgreSQL holding canon/cast/events, seeded
# from the canon bible via `make seed-canon`. The default points at a
# `settlement_radio` DB on a local server; override only if yours differs. See
# README step 4.
# DATABASE_URL=postgresql://localhost/settlement_radio

# Canon bible location (D1). The world bible is the docs/canon/ FOLDER of
# cornerstone files (docs/canon/README.md is the authoring guide). CANON_DIR is
# the folder; CANON_PATH is the legacy single-file path, used only as a fallback
# when the folder has no content. Seeding/context auto-select the folder when it's
# populated. Override only to point at a different bible. Defaults shown:
# CANON_DIR=docs/canon
# CANON_PATH=docs/CANON.md

# --- Semantic retrieval / RAG (D2) -------------------------------------------
# The writers' room recalls canon by MEANING via pgvector + a local embedding
# model (all SQL behind store.py; the model behind providers/embeddings.py).
# Anthropic has NO embeddings endpoint, so this is a third-party model — and the
# default is LOCAL/open: free, no key, no quota. NO SECRET is needed. These are the
# overridable knobs (defaults shown); set them only to switch model/provider.
#
# EMBEDDINGS_PROVIDER  — local (sentence-transformers) | voyage (hosted; not built).
# EMBEDDINGS_PROVIDER=local
# EMBEDDINGS_MODEL  — the sentence-transformers model id (downloads once, caches).
# EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDINGS_DIM  — the model's output width; it is the pgvector vector(N) column,
#   so it MUST match the model. Changing the model => re-embed + a column migration.
# EMBEDDINGS_DIM=384
# CONTEXT_CANON_TOP_K  — how many canon facts semantic recall pulls per topic
#   (unioned with the tag-match). Default 6.
# CONTEXT_CANON_TOP_K=6
# CONTEXT_QUOTES_LIMIT  — D10.2: figure quotes shown to the writers' room ("what people
#   are saying"), so the DJs can react to an opinion. 0 disables it. Default 4.
# CONTEXT_QUOTES_LIMIT=4
# CONTEXT_QUOTES_TOP_K  — semantic breadth pulled (D2 over the `quote` corpus, on topic)
#   before bounding to the limit. Default 8.
# CONTEXT_QUOTES_TOP_K=8

# --- Content-safety + continuity gates (C0) ----------------------------------
# C0 makes the gates real: no unsafe or self-contradictory draft ever reaches air.
# Every producer runs its draft through a safety gate (a fast keyword pre-filter +
# a cheap LLM pass on the haiku tier); the two-DJ room also gates on continuity. A
# flagged draft is regenerated (bounded), then dropped to a safe evergreen segment
# — never aired. Defaults are sane; you rarely set these.
#
# SAFETY_ENABLED  — master switch for the content-safety gate. Leave true in any
#   public/production run; set false ONLY for local dev to skip the LLM pass.
# SAFETY_ENABLED=true
# SAFETY_LLM_TIER=haiku          # tier for the LLM safety pass (cheap, near-live)
# SAFETY_MAX_TOKENS=200          # the reviewer just replies "OK" / "FLAG: …"
# SAFETY_MAX_ATTEMPTS=2          # draft + one regenerate before evergreen fallback
#
# CONVO_CONTINUITY_MAX_ATTEMPTS  — how many times the two-DJ room regenerates (with
#   the editor's note fed back) before dropping the slot to an evergreen fallback.
# CONVO_CONTINUITY_MAX_ATTEMPTS=2

# --- Light nightly buffer (B6) -----------------------------------------------
# `make buffer` generates a small, varied run of segments in one go (a mix of the
# three B5 formats, both DJs), each a proper Segment + a JSON sidecar, plus a run
# manifest, into segments/. Defaults are sane; override only to tune the run.
#
# BUFFER_TARGET_SEC  — roughly how much audio to make, in seconds. The run adds
#   whole segments until their length targets reach this, so it lands a little
#   OVER, never under. Default 3600 (~an hour). Lower it for a quick check; this
#   is also exposed per-run as `make buffer SECONDS=600`.
# BUFFER_TARGET_SEC=3600
#
# BUFFER_ROTATION  — which formats to cycle, in order, as a JSON list; controls
#   the *mix* of an hour, for BOTH `make buffer` and the C2 scheduler. Default
#   ["talk","news"] — `music` is DROPPED for Phase C (its [SONG] slot has nothing
#   to fill it until Phase D, so airing it would be a silent gap). e.g.
#   BUFFER_ROTATION=["news","talk"]. Re-add "music" once Phase D fills the slot.
# BUFFER_ROTATION=["talk","news"]
#
# BUFFER_MAX_SEGMENTS  — hard stop on segments per run, so a tiny per-segment
#   length can't spin an unbounded run. Default 30.
# BUFFER_MAX_SEGMENTS=30

# --- Scheduler: the real rolling buffer + playout playlist (C2) --------------
# `make schedule` (python -m src.scheduler) is the 24/7 replacement for the B6
# one-shot buffer: it keeps a rolling buffer of upcoming audio at depth, in air
# order, on MEASURED durations (ffprobe), and writes the ordered playlist that
# Liquidsoap (config/radio.liq) airs. Run it periodically (cron/systemd in C5) to
# keep the buffer topped up; `make schedule INTERVAL=300` loops it locally. It
# shares BUFFER_ROTATION (above) for the format mix. Defaults are sane.
#
# BUFFER_DEPTH_HOURS  — how much un-aired audio to keep queued ahead, in hours.
#   THE lead-time dial: deeper = more resilient to a slow/failed generation run;
#   driving it toward ~0 (+ streaming TTS) is what enables near-live later. Default 3.
# BUFFER_DEPTH_HOURS=3.0
#
# SCHEDULE_TOPUP_MAX_SEGMENTS  — hard stop on segments added in ONE top-up run, so
#   a tiny per-segment duration can't spin unbounded. Default 60.
# SCHEDULE_TOPUP_MAX_SEGMENTS=60
#
# SCHEDULE_FAILURE_MAX_RETRIES  — how many times a failing slot is retried before
#   it's skipped (never dead air — the existing buffer keeps airing). Default 1.
# SCHEDULE_FAILURE_MAX_RETRIES=1
#
# SCHEDULE_PLAYLIST_PATH  — the ordered playlist Liquidsoap re-reads. Mirrored in
#   config/radio.liq via the SCHEDULE_PLAYLIST_PATH env var. Default segments/playlist.txt.
# SCHEDULE_PLAYLIST_PATH=segments/playlist.txt
#
# SCHEDULE_STATE_PATH  — where the scheduler persists what airs when (so the next
#   top-up continues where the last left off). Default segments/schedule.json.
# SCHEDULE_STATE_PATH=segments/schedule.json

# --- AI disclosure (C3) -------------------------------------------------------
# The scheduler weaves a short spoken AI-disclosure ident into the playlist on a
# cadence (src/disclosure.py); the same written line shows on the web player + the
# YouTube description. Required when public (CLAUDE.md; EU AI Act Art. 50).
#
# DISCLOSURE_ENABLED  — master switch for the spoken ident in playout. Leave true
#   in any public/staging run; false drops it (local dev only). Default true.
# DISCLOSURE_ENABLED=true
# DISCLOSURE_EVERY_N  — air one spoken ident every N CONTENT segments. Default 4.
# DISCLOSURE_EVERY_N=4
# DISCLOSURE_VOICE  — logical voice for the ident (tts.py registry). Default the
#   night host (vell_night).
# DISCLOSURE_VOICE=vell_night

# --- Disk retention (C2.5) -------------------------------------------------
# Bound segments/ so a 24/7 run can't fill the VPS disk. The scheduler GCs aired,
# unreferenced renders at the end of each top-up; the shared disclosure ident clip
# and everything under assets/ are never collected.
#
# SEGMENT_RETENTION_HOURS  — grace past a render's air end before it's GC'd, so a
#   just-aired clip Liquidsoap may still be reading isn't yanked. Default 6.
# SEGMENT_RETENTION_HOURS=6
# SEGMENT_RETENTION_MAX_GB  — optional emergency size backstop: if segments/ still
#   exceeds this after the age sweep, the oldest aired renders are evicted until
#   under the cap. Unset = off (age-based retention only).
# SEGMENT_RETENTION_MAX_GB=20

# --- Never-dead fallback (C4) -------------------------------------------------
# config/radio.liq airs scheduled -> evergreen -> music bed -> ident -> tone so the
# stream is never silent. `make fallback` (also run at the top of every `make
# schedule`) pre-renders the evergreen pool + ident WHILE healthy and writes the
# evergreen playlist Liquidsoap watches. Liquidsoap reads these paths from env:
#
# FALLBACK_EVERGREEN_PLAYLIST_PATH  — the evergreen pool playlist. Default
#   segments/evergreen.txt (must match config/radio.liq's env default).
# FALLBACK_EVERGREEN_PLAYLIST_PATH=segments/evergreen.txt
# FALLBACK_IDENT_PATH  — the deepest spoken fallback (the disclosure ident clip).
#   Read only by config/radio.liq; default matches the kokoro/vell_night clip. Set
#   this if you change TTS_PROVIDER or DISCLOSURE_VOICE.
# FALLBACK_IDENT_PATH=segments/ident-disclosure-kokoro-vell_night.mp3
#   (Drop an optional music bed at assets/bed.mp3 to use the music-bed tier.)

# --- Health checks + alerts (C4) ----------------------------------------------
# `make health` (python -m src.health; cron/systemd in C5) checks the live schedule
# + stream and alerts when the air is at risk. It exits non-zero when unhealthy so a
# timer can act on it. All alert URLs default empty (log-only) — set them on the VPS.
#
# HEALTH_MIN_RUNWAY_MINUTES  — alert when less than this much audio is queued ahead.
#   Default 20.
# HEALTH_MIN_RUNWAY_MINUTES=20
# HEALTH_MAX_RUN_AGE_MINUTES  — alert when no scheduler top-up completed within this
#   long (the "generator stopped running" detector). Keep it comfortably ABOVE your
#   top-up cadence. Default 90.
# HEALTH_MAX_RUN_AGE_MINUTES=90
# HEALTH_STREAM_URL  — Icecast mount to liveness-check; empty skips the stream check.
# HEALTH_STREAM_URL=http://127.0.0.1:8000/settlement.mp3
# HEALTH_PING_URL  — dead-man's-switch ping (e.g. a healthchecks.io URL): pinged on
#   a clean pass, pinged at <url>/fail on an issue. Empty = no ping.
# HEALTH_PING_URL=
# HEALTH_ALERT_WEBHOOK_URL  — POST {"text": …} alerts here (Slack/Discord/generic).
# HEALTH_ALERT_WEBHOOK_URL=
# HEALTH_REQUEST_TIMEOUT_SEC=10.0

# --- World tick: the generative world engine (D3) ----------------------------
# The nightly tick (python -m src.world.world_tick) invents NEW bible-consistent
# happenings as dated, arced stories and writes them to the story log (D3.0). Every
# proposal passes safety + a world-continuity gate before it's written (flagged ones
# are regenerated once, then dropped — never written). Defaults are sane.
#
# WORLD_TICK_NEW_STORIES_MIN / _MAX  — how many new happenings one tick proposes,
#   a mix of large + small. Defaults 2 / 4.
# WORLD_TICK_NEW_STORIES_MIN=2
# WORLD_TICK_NEW_STORIES_MAX=4
# WORLD_TICK_LARGE_RATIO  — share of new stories aimed to be "large". Default 0.34.
# WORLD_TICK_LARGE_RATIO=0.34
# WORLD_TICK_PROPOSE_TIER  — model tier for the generation (sonnet writing brain).
# WORLD_TICK_PROPOSE_TIER=sonnet
# WORLD_TICK_CONTINUITY_TIER  — model tier for the continuity gate. Default sonnet.
# WORLD_TICK_CONTINUITY_TIER=sonnet
# WORLD_TICK_MAX_ATTEMPTS  — draft + one regenerate before a flagged story is dropped.
# WORLD_TICK_MAX_ATTEMPTS=2
# WORLD_TICK_BEAT_HORIZON_DAYS  — max |in-world days| from now a generated beat may be
#   dated, so the clock frames new beats within a believable window. Default 21.
# WORLD_TICK_BEAT_HORIZON_DAYS=21
#
# Continuity (D3.2) — advancing running stories so the world has day-to-day movement.
# WORLD_TICK_ADVANCE_MAX  — max running stories advanced per tick (least-recently-
#   advanced first). Default 3.
# WORLD_TICK_ADVANCE_MAX=3
# WORLD_TICK_RESOLVE_AFTER_TICKS  — steer a story older than this toward resolution
#   (arc stage `past`, after which it stops advancing). Keeps the world from piling up.
# WORLD_TICK_RESOLVE_AFTER_TICKS=5
#
# Variety / balance / de-dup (D3.3) — keep the generated world from looping.
# WORLD_TICK_MAX_ACTIVE_STORIES  — new-vs-advance PACING cap: at/over this many running
#   stories the tick proposes NO new ones (advance/resolve only). Default 24.
# WORLD_TICK_MAX_ACTIVE_STORIES=24
# WORLD_TICK_DOMAIN_WINDOW_TICKS  — recent ticks counted for domain balance. Default 7.
# WORLD_TICK_DOMAIN_WINDOW_TICKS=7
# WORLD_TICK_QUIET_DOMAINS  — how many least-used domains to spotlight each tick. Default 4.
# WORLD_TICK_QUIET_DOMAINS=4
# WORLD_TICK_DEDUP_THRESHOLD  — semantic cosine cutoff (D2 recall over the story corpus)
#   above which a proposal is a near-duplicate and rejected. Default 0.86.
# WORLD_TICK_DEDUP_THRESHOLD=0.86
# WORLD_TICK_DEDUP_JACCARD  — structural title/summary token-overlap cutoff (within-batch
#   + the fallback when D2 is off). Default 0.6.
# WORLD_TICK_DEDUP_JACCARD=0.6
#
# D10.1 — the tick PEOPLES its stories: invented figures + their attributable, dated
# quotes, generated in the same gated/batched call (a flagged one drops/regenerates with
# its story; a continuing story reuses its figures by name). Invented people ONLY (IP rule).
# WORLD_TICK_FIGURES_ENABLED  — master toggle; false => stories stay people-less. Default true.
# WORLD_TICK_FIGURES_ENABLED=true
# WORLD_TICK_FIGURES_PER_STORY_MAX  — cap on figures per story (a few voices, not a crowd). 3.
# WORLD_TICK_FIGURES_PER_STORY_MAX=3
# WORLD_TICK_QUOTES_PER_STORY_MAX  — cap on quotes per story. Default 4.
# WORLD_TICK_QUOTES_PER_STORY_MAX=4
# WORLD_TICK_ADVANCE_NEW_FIGURES_MAX  — reuse-vs-new: max NEW people an advancement adds
#   (a continuing story mostly reuses existing figures). Default 1.
# WORLD_TICK_ADVANCE_NEW_FIGURES_MAX=1
#
# Cost lever — the Batch API (50% off) behind providers/llm.generate_batch. The tick
# is nightly, not live, so it batches its gate calls.
# LLM_BATCH_ENABLED  — true (default) submits a real async batch; FALSE runs the
#   requests synchronously via the normal path (no async wait, full price) — handy for
#   a quick local `make world-tick`. Leave true on the box for the discount.
# LLM_BATCH_ENABLED=true
# LLM_BATCH_POLL_INTERVAL_SEC=30
# LLM_BATCH_MAX_WAIT_SEC=86400   # batches may take up to 24h; a longer run fails loud

# --- News desk: the story-log-driven bulletin (D4) ----------------------------
# The desk (src/formats/news.py) SELECTS which running stories (D3 log) each hour's
# bulletin reports, tags each new/repeat/evolve from its coverage memory (D4.0), and
# frames it by arc + beat date. All defaults are sane; tune the SELECTION MIX here.
# NEWS_STORY_COUNT  — stories per bulletin (the old headline count). Default 3.
# NEWS_STORY_COUNT=3
# NEWS_TARGET_BREAKING / _TRAILED / _ONGOING  — soft per-kind quotas for the mix
#   (filled by rank, never exceeding the count). Defaults 2 / 1 / 1.
# NEWS_TARGET_BREAKING=2
# NEWS_TARGET_TRAILED=1
# NEWS_TARGET_ONGOING=1
# NEWS_BREAKING_WINDOW_HOURS  — a beat within this many hours of now is "breaking". 18.
# NEWS_BREAKING_WINDOW_HOURS=18
# NEWS_TRAIL_HORIZON_DAYS  — an upcoming beat within this many days is "trailed". 7.
# NEWS_TRAIL_HORIZON_DAYS=7
# NEWS_REPEAT_MAX_STALE_HOURS  — drop a repeat (no new beat) older than this. 18.
# NEWS_REPEAT_MAX_STALE_HOURS=18
# NEWS_CANON_RECALL_K / _CANON_WEIGHT  — canon-grounding (D2): nearest facts + its
#   weight in the rank (degrades to temporal-only when RAG is off). Defaults 8 / 0.5.
# NEWS_CANON_RECALL_K=8
# NEWS_CANON_WEIGHT=0.5
# NEWS_BREAKING_BONUS / _EVOLVE_BONUS  — rank lift for breaking + freshly-developed
#   stories so they lead the bulletin. Defaults 1.0 / 0.5.
# NEWS_BREAKING_BONUS=1.0
# NEWS_EVOLVE_BONUS=0.5
# Continuity (D4.3): prior coverage is fed in for consistent naming, then an editor
# pass checks the draft; a flag re-rolls with the note, bounded then evergreen (C0).
# NEWS_CONTINUITY_MAX_ATTEMPTS  — drafts before the evergreen fallback. Default 2.
# NEWS_CONTINUITY_MAX_ATTEMPTS=2
# NEWS_CONTINUITY_TIER  — model for the editor pass. Default sonnet.
# NEWS_CONTINUITY_TIER=sonnet
# NEWS_CONTINUITY_ESCALATION_TIER  — confirm a flag before re-rolling. Default opus.
# NEWS_CONTINUITY_ESCALATION_TIER=opus
# NEWS_CONTINUITY_MAX_TOKENS=300
# NEWS_QUOTES_PER_STORY  — D10.2: figure quotes carried in each story's brief so the
#   anchor can attribute them ("X, the relay-keeper, said yesterday: …") with temporal
#   framing. 0 disables quote attribution. Default 2.
# NEWS_QUOTES_PER_STORY=2
# Bulletin LENGTH + register live under FORMAT_NEWS_* (a full ~5-min hourly bulletin
# by default). Spoken news is ~140-160 wpm and LLMs undershoot, so target high.
# FORMAT_NEWS_WORDS_LOW=800
# FORMAT_NEWS_WORDS_HIGH=1000
# FORMAT_NEWS_MAX_TOKENS=1600          # must fit the word target (~1.3 tokens/word + headroom)
# FORMAT_NEWS_LENGTH_TARGET_SEC=300    # scheduler metadata; playlist is timed on the real render
# FORMAT_NEWS_SPEAKER_ID=vell          # the anchor (its cast card shapes the on-air voice)

# --- Freshness / anti-repetition (D5) ----------------------------------------
# A small airplay memory (airplay_history) records what aired recently — features
# only, never audio — so the showrunner avoids re-picking a recent beat and producers
# avoid reusing openings. DISTINCT from D4's per-story coverage: D4 drives which
# stories recur; D5 keeps the WORDING fresh on top. Defaults are conservative (soft +
# small): over-constraining can starve a small canon, and D3's moving world is the real
# source of variety. See it: make freshness-demo (a few Claude calls, no TTS).
# FRESHNESS_ENABLED  — master toggle; false = the writers' room ignores the memory. true.
# FRESHNESS_ENABLED=true
# FRESHNESS_WINDOW_HOURS  — the "recently on air" look-back (broadcast timeline). Keep it
#   comfortably ABOVE BUFFER_DEPTH_HOURS so the whole upcoming buffer counts as recent. 6.
# FRESHNESS_WINDOW_HOURS=6.0
# FRESHNESS_MODE  — influence strength: "prefer" (soft nudge) | "avoid" (hard don't-reuse).
# FRESHNESS_MODE=prefer
# FRESHNESS_RECENT_LIMIT  — max recent topics/openings shown in a prompt block. 6.
# FRESHNESS_RECENT_LIMIT=6
# FRESHNESS_RETENTION_MARGIN  — the airplay sweep keeps rows for WINDOW × this, then drops
#   them (its OWN bound — NOT the C2.5 audio GC; this memory must outlive the audio). 4.
# FRESHNESS_RETENTION_MARGIN=4.0

# --- Programming backbone + status console (D6) ------------------------------
# The station is a PROGRAMMED weekly grid (docs/programming/grid.yaml — the human-edited
# source of truth), not a flat rotation: each in-world hour maps to a named program with
# its own hosts, framing, and format CLOCK (a real-radio sequence with run-lengths +
# pinned top-of-hour slots). Edit the file, no restart needed (it's mtime-reloaded). See
# it token-free: make programming-demo. Full grid MANAGEMENT (a web editor) is Phase E.
# PROGRAMMING_ENABLED  — master switch. false = rollback to the flat BUFFER_ROTATION
#   (pre-D6 behaviour); true = the grid drives what/who airs, and BUFFER_ROTATION becomes
#   only the default program's fallback mix. true.
# PROGRAMMING_ENABLED=true
# PROGRAMMING_GRID_PATH  — the weekly-grid YAML. docs/programming/grid.yaml.
# PROGRAMMING_GRID_PATH=docs/programming/grid.yaml
# PROGRAMMING_DEFAULT_PROGRAM  — the reserved fallback program id returned when no slot
#   matches, so the scheduler never stalls (legacy hour-derived framing). default.
# PROGRAMMING_DEFAULT_PROGRAM=default
# PROGRAMMING_CONSOLE_UPCOMING  — how many upcoming entries the operator console prints. 8.
# PROGRAMMING_CONSOLE_UPCOMING=8
# CONSOLE_STORY_LIMIT  — active stories shown in the console's D3 story-log panel. 6.
# CONSOLE_STORY_LIMIT=6
# CONSOLE_BEATS_PER_STORY  — newest beats shown per story in that panel. 1.
# CONSOLE_BEATS_PER_STORY=1
# NOWPLAYING_FEED_PATH  — where the PUBLIC now-playing feed JSON is written (the C8 web
#   player reads it; public-safe fields only). segments/nowplaying.json.
# NOWPLAYING_FEED_PATH=segments/nowplaying.json
# NOWPLAYING_NEXT_COUNT  — how many upcoming items the public feed lists. 3.
# NOWPLAYING_NEXT_COUNT=3

# --- Production media / the D7 sound design layer -------------------------------------
# Curated audio (jingles/idents/stings/beds/songs) lives under assets/ — gitignored,
# backed up, and never in the disk GC's path. The clip->placement mapping itself is a
# code registry (src/production/media.py), not env config; these are the operator dials.
# ASSETS_DIR  — the home of ALL curated media. assets/.
# ASSETS_DIR=assets
# TRACKS_MANIFEST_PATH  — the human-authored music-lore manifest `make seed-tracks` reads
#   (the source of truth for the `tracks` table). config/tracks.yaml.
# TRACKS_MANIFEST_PATH=config/tracks.yaml
# PRODUCTION_BED_GAIN_DB  — how far a bed sits BELOW the untouched speech when baked
#   (more negative = quieter bed; over-bedding is worse than none). -15.0.
# PRODUCTION_BED_GAIN_DB=-15.0
# PRODUCTION_BED_FADE_SEC  — the bed's fade-in/out so it never pops. 1.5.
# PRODUCTION_BED_FADE_SEC=1.5
# PRODUCTION_THEME_AT_BOUNDARY  — open each program change with its theme (handover
#   programs get the B6 sting first). true.
# PRODUCTION_THEME_AT_BOUNDARY=true
# PRODUCTION_STING_BEFORE_NEWS  — fire the C8 sting immediately before every bulletin. true.
# PRODUCTION_STING_BEFORE_NEWS=true
# PRODUCTION_IDENT_EVERY_N  — air the A1 sung station ident every N CONTENT segments
#   (0 = off; separate from the C3 disclosure-ident cadence, which keeps airing). 8.
# PRODUCTION_IDENT_EVERY_N=8
# PRODUCTION_BEDDED_PROGRAMS / PRODUCTION_BEDDED_FORMATS  — beds are DOUBLY opt-in: a
#   slot is bedded only when its program AND its format are both listed (news stays dry
#   even inside a bedded program). JSON lists. ["long_night"] / ["talk"].
# PRODUCTION_BEDDED_PROGRAMS=["long_night"]
# PRODUCTION_BEDDED_FORMATS=["talk"]

# --- The music selector (D7.4 — the rule-based "what to play" brain) --------------------
# Deterministic weighted policy over the curated catalogue (src/production/selector.py);
# the LLM only writes the intro/back-announce around the pick. Weights are additive
# scores; penalties subtract. Defaults are conservative — tune by ear.
# MUSIC_SELECT_DAYPART_WEIGHT  — bonus for a mood matching the program's daypart. 2.0.
# MUSIC_SELECT_DAYPART_WEIGHT=2.0
# MUSIC_SELECT_WORLD_WEIGHT  — bonus for answering the live story log's tone. 1.0.
# MUSIC_SELECT_WORLD_WEIGHT=1.0
# MUSIC_SELECT_FEATURED_WEIGHT  — bonus for an artist named in a running story, or a
#   track tagged `featured`/`pinned` in config/tracks.yaml. 3.0.
# MUSIC_SELECT_FEATURED_WEIGHT=3.0
# MUSIC_SELECT_REPEAT_TRACK_PENALTY  — penalty for a track aired within the D5 freshness
#   window (effectively excludes it). 8.0.
# MUSIC_SELECT_REPEAT_TRACK_PENALTY=8.0
# MUSIC_SELECT_REPEAT_ARTIST_PENALTY  — penalty for an artist aired within the window. 3.0.
# MUSIC_SELECT_REPEAT_ARTIST_PENALTY=3.0
# MUSIC_SELECT_ERA_REPEAT_PENALTY  — penalty for sitting in the same era as the last
#   spin (the variety spread). 1.0.
# MUSIC_SELECT_ERA_REPEAT_PENALTY=1.0
# MUSIC_SELECT_JITTER  — seeded per-slot variety so equal-scored tracks rotate;
#   deterministic given the slot's air time. 0.5.
# MUSIC_SELECT_JITTER=0.5

# --- Commercials & promos (D8.0 — in-world spots; texture, not interruption) ---
# The `commercial`/`promo` formats (src/formats/commercial.py): `commercial`
# invents a fictional +600y product spot FRESH every airing (never a rotating
# reel); `promo` promotes the station / the current named show, truthfully.
# Both run the C0 safety gate + evergreen fallback like every producer.
# FORMAT_COMMERCIAL_SPEAKER_ID  — the host card whose voice reads the spot. vell.
# FORMAT_COMMERCIAL_SPEAKER_ID=vell
# FORMAT_COMMERCIAL_WORDS_LOW=55
# FORMAT_COMMERCIAL_WORDS_HIGH=90
# FORMAT_COMMERCIAL_MAX_TOKENS=300
# FORMAT_COMMERCIAL_LENGTH_TARGET_SEC=40   # a ~30-40s spot; scheduler metadata
# FORMAT_COMMERCIAL_PRODUCTION_LEVEL  — how "produced" a spot sounds: 1 voiced read
#   (default) | 2 read over a ducked bed (D7) | 3 multi-voice/testimonial (needs
#   D9/D10; degrades to 1) | 4 curated brand-sting bookend (degrades to 1 while no
#   clip is on disk). The EFFECTIVE level lands in the segment meta. Default 1.
# FORMAT_COMMERCIAL_PRODUCTION_LEVEL=1
# The ad-break cadence (D8.1): WHERE/HOW OFTEN a break airs is the GRID's call — a
# program's `break_every: N` in docs/programming/grid.yaml (absent/0 = no breaks in
# that show). These dials only shape the break itself. Defaults are SPARSE on
# purpose — over-running ads is worse than none.
# COMMERCIAL_BREAK_ENABLED  — master toggle for the whole D8.1 weave. true.
# COMMERCIAL_BREAK_ENABLED=true
# COMMERCIAL_BREAK_MAX_SEGMENTS  — spots per break; keep to one or two. 1.
# COMMERCIAL_BREAK_MAX_SEGMENTS=1
# COMMERCIAL_BREAK_PROMO_EVERY_N  — every Nth spot (across breaks) is a station
#   promo instead of a commercial; 0 = commercials only. 3.
# COMMERCIAL_BREAK_PROMO_EVERY_N=3
# Real supporter "Powered by" reads (D8.2) — ALWAYS "Powered by", never "Sponsored
# by" (docs/MARKETING.md; the lead-in is templated so it can't drift). Sponsors are
# hand-entered catalog: config/sponsors.yaml -> `make seed-sponsors`; survives
# seed-canon/reset-world. SHIPS EMPTY — real sponsors are added at CM (donations
# live); until then no reads air.
# SPONSORS_MANIFEST_PATH=config/sponsors.yaml
# SPONSOR_READ_EVERY_N_BREAKS  — one read inside every Nth ad break; 0 = off. 2.
# SPONSOR_READ_EVERY_N_BREAKS=2
# SPONSOR_READ_VOICE  — logical tts.py voice for the read (station voice). vell_night.
# SPONSOR_READ_VOICE=vell_night
