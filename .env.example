# Copy this file to .env and fill in the values. NEVER commit .env.
# These are every key/setting Phase A ("Proof of Loop") needs.

# --- Intelligence (T1, T3): Anthropic API / Claude ---
# Requires a non-zero account balance (free-trial credits are fine).
# Get one at https://console.anthropic.com/ -> API keys.
ANTHROPIC_API_KEY=

# --- Voice (T1, T4): ElevenLabs TTS ---
# Optional now — only needed if you set TTS_PROVIDER=elevenlabs (flagship voice).
# Free tier covers only ~2 segments/month. https://elevenlabs.io/ -> API key.
ELEVENLABS_API_KEY=

# Which TTS implementation the tts.py seam selects:
#   kokoro      DEFAULT — self-hosted open-weight neural voice; free, unlimited,
#               offline after the one-time model download (no key). See README
#               "Kokoro (local TTS)" for the install steps.
#   elevenlabs  flagship cloud voice (needs ELEVENLABS_API_KEY + credits; the
#               free tier runs dry fast). Reserved for later premium use.
#   say         macOS built-in `say` — offline fallback if Kokoro won't install.
#   orpheus     future self-hosted option, not built yet.
# Override per-run, e.g.:  TTS_PROVIDER=elevenlabs make play
TTS_PROVIDER=kokoro

# --- Playout (T5): local Icecast ---
# Password Liquidsoap uses to push the stream into Icecast. Local-only, so any
# value works; this default is fine if you don't change it on both sides.
ICECAST_SOURCE_PASSWORD=hackme

# --- Foundation (B0.5): config + logging -------------------------------------
# EVERY field in src/config.py can be overridden by an env var of the same name
# (case-insensitive), so you rarely need to set these — the defaults are sane.
# The most useful knobs:
#
# Logging: level (debug|info|warning|error) and format. LOG_JSON=false gives
# human-pretty console output for local dev; true (default) is JSON for 24/7.
# LOG_LEVEL=info
# LOG_JSON=true
#
# Bounded retry on external (Claude/TTS) calls.
# RETRY_ATTEMPTS=3
# RETRY_BACKOFF_SEC=2.0
#
# World-state database (B1). Local PostgreSQL holding canon/cast/events, seeded
# from the canon bible via `make seed-canon`. The default points at a
# `settlement_radio` DB on a local server; override only if yours differs. See
# README step 4.
# DATABASE_URL=postgresql://localhost/settlement_radio

# Canon bible location (D1). The world bible is the docs/canon/ FOLDER of
# cornerstone files (docs/canon/README.md is the authoring guide). CANON_DIR is
# the folder; CANON_PATH is the legacy single-file path, used only as a fallback
# when the folder has no content. Seeding/context auto-select the folder when it's
# populated. Override only to point at a different bible. Defaults shown:
# CANON_DIR=docs/canon
# CANON_PATH=docs/CANON.md

# --- Semantic retrieval / RAG (D2) -------------------------------------------
# The writers' room recalls canon by MEANING via pgvector + a local embedding
# model (all SQL behind store.py; the model behind providers/embeddings.py).
# Anthropic has NO embeddings endpoint, so this is a third-party model — and the
# default is LOCAL/open: free, no key, no quota. NO SECRET is needed. These are the
# overridable knobs (defaults shown); set them only to switch model/provider.
#
# EMBEDDINGS_PROVIDER  — local (sentence-transformers) | voyage (hosted; not built).
# EMBEDDINGS_PROVIDER=local
# EMBEDDINGS_MODEL  — the sentence-transformers model id (downloads once, caches).
# EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDINGS_DIM  — the model's output width; it is the pgvector vector(N) column,
#   so it MUST match the model. Changing the model => re-embed + a column migration.
# EMBEDDINGS_DIM=384
# CONTEXT_CANON_TOP_K  — how many canon facts semantic recall pulls per topic
#   (unioned with the tag-match). Default 6.
# CONTEXT_CANON_TOP_K=6

# --- Content-safety + continuity gates (C0) ----------------------------------
# C0 makes the gates real: no unsafe or self-contradictory draft ever reaches air.
# Every producer runs its draft through a safety gate (a fast keyword pre-filter +
# a cheap LLM pass on the haiku tier); the two-DJ room also gates on continuity. A
# flagged draft is regenerated (bounded), then dropped to a safe evergreen segment
# — never aired. Defaults are sane; you rarely set these.
#
# SAFETY_ENABLED  — master switch for the content-safety gate. Leave true in any
#   public/production run; set false ONLY for local dev to skip the LLM pass.
# SAFETY_ENABLED=true
# SAFETY_LLM_TIER=haiku          # tier for the LLM safety pass (cheap, near-live)
# SAFETY_MAX_TOKENS=200          # the reviewer just replies "OK" / "FLAG: …"
# SAFETY_MAX_ATTEMPTS=2          # draft + one regenerate before evergreen fallback
#
# CONVO_CONTINUITY_MAX_ATTEMPTS  — how many times the two-DJ room regenerates (with
#   the editor's note fed back) before dropping the slot to an evergreen fallback.
# CONVO_CONTINUITY_MAX_ATTEMPTS=2

# --- Light nightly buffer (B6) -----------------------------------------------
# `make buffer` generates a small, varied run of segments in one go (a mix of the
# three B5 formats, both DJs), each a proper Segment + a JSON sidecar, plus a run
# manifest, into segments/. Defaults are sane; override only to tune the run.
#
# BUFFER_TARGET_SEC  — roughly how much audio to make, in seconds. The run adds
#   whole segments until their length targets reach this, so it lands a little
#   OVER, never under. Default 3600 (~an hour). Lower it for a quick check; this
#   is also exposed per-run as `make buffer SECONDS=600`.
# BUFFER_TARGET_SEC=3600
#
# BUFFER_ROTATION  — which formats to cycle, in order, as a JSON list; controls
#   the *mix* of an hour, for BOTH `make buffer` and the C2 scheduler. Default
#   ["talk","news"] — `music` is DROPPED for Phase C (its [SONG] slot has nothing
#   to fill it until Phase D, so airing it would be a silent gap). e.g.
#   BUFFER_ROTATION=["news","talk"]. Re-add "music" once Phase D fills the slot.
# BUFFER_ROTATION=["talk","news"]
#
# BUFFER_MAX_SEGMENTS  — hard stop on segments per run, so a tiny per-segment
#   length can't spin an unbounded run. Default 30.
# BUFFER_MAX_SEGMENTS=30

# --- Scheduler: the real rolling buffer + playout playlist (C2) --------------
# `make schedule` (python -m src.scheduler) is the 24/7 replacement for the B6
# one-shot buffer: it keeps a rolling buffer of upcoming audio at depth, in air
# order, on MEASURED durations (ffprobe), and writes the ordered playlist that
# Liquidsoap (config/radio.liq) airs. Run it periodically (cron/systemd in C5) to
# keep the buffer topped up; `make schedule INTERVAL=300` loops it locally. It
# shares BUFFER_ROTATION (above) for the format mix. Defaults are sane.
#
# BUFFER_DEPTH_HOURS  — how much un-aired audio to keep queued ahead, in hours.
#   THE lead-time dial: deeper = more resilient to a slow/failed generation run;
#   driving it toward ~0 (+ streaming TTS) is what enables near-live later. Default 3.
# BUFFER_DEPTH_HOURS=3.0
#
# SCHEDULE_TOPUP_MAX_SEGMENTS  — hard stop on segments added in ONE top-up run, so
#   a tiny per-segment duration can't spin unbounded. Default 60.
# SCHEDULE_TOPUP_MAX_SEGMENTS=60
#
# SCHEDULE_FAILURE_MAX_RETRIES  — how many times a failing slot is retried before
#   it's skipped (never dead air — the existing buffer keeps airing). Default 1.
# SCHEDULE_FAILURE_MAX_RETRIES=1
#
# SCHEDULE_PLAYLIST_PATH  — the ordered playlist Liquidsoap re-reads. Mirrored in
#   config/radio.liq via the SCHEDULE_PLAYLIST_PATH env var. Default segments/playlist.txt.
# SCHEDULE_PLAYLIST_PATH=segments/playlist.txt
#
# SCHEDULE_STATE_PATH  — where the scheduler persists what airs when (so the next
#   top-up continues where the last left off). Default segments/schedule.json.
# SCHEDULE_STATE_PATH=segments/schedule.json

# --- AI disclosure (C3) -------------------------------------------------------
# The scheduler weaves a short spoken AI-disclosure ident into the playlist on a
# cadence (src/disclosure.py); the same written line shows on the web player + the
# YouTube description. Required when public (CLAUDE.md; EU AI Act Art. 50).
#
# DISCLOSURE_ENABLED  — master switch for the spoken ident in playout. Leave true
#   in any public/staging run; false drops it (local dev only). Default true.
# DISCLOSURE_ENABLED=true
# DISCLOSURE_EVERY_N  — air one spoken ident every N CONTENT segments. Default 4.
# DISCLOSURE_EVERY_N=4
# DISCLOSURE_VOICE  — logical voice for the ident (tts.py registry). Default the
#   night host (vell_night).
# DISCLOSURE_VOICE=vell_night

# --- Disk retention (C2.5) -------------------------------------------------
# Bound segments/ so a 24/7 run can't fill the VPS disk. The scheduler GCs aired,
# unreferenced renders at the end of each top-up; the shared disclosure ident clip
# and everything under assets/ are never collected.
#
# SEGMENT_RETENTION_HOURS  — grace past a render's air end before it's GC'd, so a
#   just-aired clip Liquidsoap may still be reading isn't yanked. Default 6.
# SEGMENT_RETENTION_HOURS=6
# SEGMENT_RETENTION_MAX_GB  — optional emergency size backstop: if segments/ still
#   exceeds this after the age sweep, the oldest aired renders are evicted until
#   under the cap. Unset = off (age-based retention only).
# SEGMENT_RETENTION_MAX_GB=20

# --- Never-dead fallback (C4) -------------------------------------------------
# config/radio.liq airs scheduled -> evergreen -> music bed -> ident -> tone so the
# stream is never silent. `make fallback` (also run at the top of every `make
# schedule`) pre-renders the evergreen pool + ident WHILE healthy and writes the
# evergreen playlist Liquidsoap watches. Liquidsoap reads these paths from env:
#
# FALLBACK_EVERGREEN_PLAYLIST_PATH  — the evergreen pool playlist. Default
#   segments/evergreen.txt (must match config/radio.liq's env default).
# FALLBACK_EVERGREEN_PLAYLIST_PATH=segments/evergreen.txt
# FALLBACK_IDENT_PATH  — the deepest spoken fallback (the disclosure ident clip).
#   Read only by config/radio.liq; default matches the kokoro/vell_night clip. Set
#   this if you change TTS_PROVIDER or DISCLOSURE_VOICE.
# FALLBACK_IDENT_PATH=segments/ident-disclosure-kokoro-vell_night.mp3
#   (Drop an optional music bed at assets/bed.mp3 to use the music-bed tier.)

# --- Health checks + alerts (C4) ----------------------------------------------
# `make health` (python -m src.health; cron/systemd in C5) checks the live schedule
# + stream and alerts when the air is at risk. It exits non-zero when unhealthy so a
# timer can act on it. All alert URLs default empty (log-only) — set them on the VPS.
#
# HEALTH_MIN_RUNWAY_MINUTES  — alert when less than this much audio is queued ahead.
#   Default 20.
# HEALTH_MIN_RUNWAY_MINUTES=20
# HEALTH_MAX_RUN_AGE_MINUTES  — alert when no scheduler top-up completed within this
#   long (the "generator stopped running" detector). Keep it comfortably ABOVE your
#   top-up cadence. Default 90.
# HEALTH_MAX_RUN_AGE_MINUTES=90
# HEALTH_STREAM_URL  — Icecast mount to liveness-check; empty skips the stream check.
# HEALTH_STREAM_URL=http://127.0.0.1:8000/settlement.mp3
# HEALTH_PING_URL  — dead-man's-switch ping (e.g. a healthchecks.io URL): pinged on
#   a clean pass, pinged at <url>/fail on an issue. Empty = no ping.
# HEALTH_PING_URL=
# HEALTH_ALERT_WEBHOOK_URL  — POST {"text": …} alerts here (Slack/Discord/generic).
# HEALTH_ALERT_WEBHOOK_URL=
# HEALTH_REQUEST_TIMEOUT_SEC=10.0
